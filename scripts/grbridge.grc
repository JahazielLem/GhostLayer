- [lora_tx_0, '0', blocks_multiply_const_vxx_0, '0']
- [low_pass_filter_0, '0', iio_pluto_sink_0, '0']
- [zeromq_pull_msg_source_0, out, lora_tx_0, in]

metadata:
  file_format: 1
  grc_version: 3.10.12.0
